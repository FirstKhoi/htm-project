@startuml
skinparam rectangle {
  BackgroundColor #F8FAFC
  BorderColor #334155
}
skinparam database {
  BackgroundColor #EEF2FF
  BorderColor #334155
}

actor "Admin / Staff" as Staff
actor Customer
rectangle "Process 0:\nHotel Management System" as HMS
database "D0: SQLite Database" as DB

Staff --> HMS : Login\nManage rooms/bookings/customers\nView dashboard and reports
HMS --> Staff : Auth status\nOperation results\nAnalytics and status

Customer --> HMS : Register / login / forgot password\nBrowse rooms after login\nSubmit booking request
HMS --> Customer : Auth result\nRoom catalog\nBooking response

HMS --> DB : Read/Write business data
DB --> HMS : Users, rooms, bookings,\ncustomers, payments

@enduml
