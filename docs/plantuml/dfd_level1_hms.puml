@startuml
left to right direction
skinparam rectangle {
  BackgroundColor #F8FAFC
  BorderColor #334155
}
skinparam database {
  BackgroundColor #EEF2FF
  BorderColor #334155
}

actor "Admin / Staff" as Staff
actor Customer

rectangle "1.0 Auth & Session" as P1
rectangle "2.0 Room Management" as P2
rectangle "3.0 Booking Workflow" as P3
rectangle "4.0 Customer Management" as P4
rectangle "5.0 Payment & Reporting" as P5

database "D1 Users" as D1
database "D2 Rooms" as D2
database "D3 Customers" as D3
database "D4 Bookings" as D4
database "D5 Payments" as D5

Staff --> P1 : Login / Logout / Forgot password
Customer --> P1 : Register / Login / Logout / Forgot password
P1 --> D1 : Create/find/update user
P1 --> D3 : Create linked customer (on register)
P1 --> Staff : Auth status
P1 --> Customer : Auth status

Staff --> P2 : Add/update/delete room\nUpdate room status
Customer --> P2 : Browse rooms after login
P2 --> D2 : CRUD rooms + status
P2 --> Staff : Room operation result
P2 --> Customer : Room catalog

Staff --> P4 : Add/update/delete customer\nSearch + export CSV
P4 --> D3 : CRUD/search customers
P4 --> Staff : Customer list / export file

Staff --> P3 : Create/approve/check-in/check-out/cancel
Customer --> P3 : Booking request
P3 --> D4 : Create/update booking
P3 --> D2 : Validate room availability\nUpdate room status
P3 --> D3 : Find linked customer\nUpdate tier stats
P3 --> D5 : Create payment / refund records
P3 --> Staff : Booking workflow result
P3 --> Customer : Booking request result

Staff --> P5 : Open reports + date filter
P5 --> D5 : Read payments
P5 --> D4 : Read bookings for metrics
P5 --> D2 : Read rooms for occupancy
P5 --> D3 : Read customers for payment timeline
P5 --> Staff : Revenue, ADR, RevPAR,\nTop rooms, payment timeline

@enduml
